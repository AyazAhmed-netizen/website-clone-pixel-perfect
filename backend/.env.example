# Perfect Web Clone - Environment Variables

# ====================================
# Backend Configuration
# ====================================

# Backend server port
PORT=5001

# ====================================
# AI Provider Configuration
# ====================================

# Provider type: anthropic | openai | custom_openai_compatible | custom_anthropic_compatible | groq | mistral
LLM_PROVIDER=custom_openai_compatible

# API key for the selected provider
LLM_API_KEY=nvapi

# Base URL (required for custom/groq/mistral/openai providers)
LLM_BASE_URL=https://integrate.api.nvidia.com/v1

# Model name
LLM_MODEL=nvidia/nemotron-3-ultra-550b-a55b

# Log level (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO
